# Copy this file to .env and fill in real values. .env is gitignored.
# Gmail sender account (use a dedicated/throwaway account + an App Password, NOT your login password)
EMAIL_USER=your-bot-account@gmail.com
EMAIL_PASS=your-16-char-gmail-app-password
# Comma-separated recipients of the apartment alerts
EMAIL_TO=you@example.com, partner@example.com
# Google AI Studio (Gemini) API key — for free-text email preference parsing. Optional.
GEMINI_API_KEY=
# Comma-separated senders allowed to change preferences by replying to an alert
ALLOWED_SENDERS=you@example.com, partner@example.com
# Optional Telegram alerts
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
